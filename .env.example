# Copy to .env and fill in. Only the two API keys are required for a live run.

# Required for live runs (not needed when replaying cassettes with LLM_MODE=replay)
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# Models (optional overrides)
AGENT_MODEL=gpt-4o
SUMMARY_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini

# Budgets (optional overrides)
STEP_BUDGET=20
TOKEN_BUDGET=120000
WALL_CLOCK_BUDGET=600        # seconds; 0 disables

# Fresh-context critic (optional overrides)
VERIFY_ENABLED=true
MAX_VERIFY_RETRIES=2

# Context compaction (optional overrides)
COMPACT_FINDINGS_AFTER=12
COMPACT_FINDINGS_RECENT=6

# Skills (off by default; turn on for legal drafting/review via the paralegal skill)
SKILLS_ENABLED=true

# LLM cassette mode: live | record | replay
#   live   - call the API normally (default)
#   record - call the API and save responses to eval/cassettes/
#   replay - serve responses from eval/cassettes/ (no network, deterministic)
LLM_MODE=live
